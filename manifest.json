{
  "manifest_version": 3,
  "name": "LyricVibe",
  "version": "0.2.0",
  "description": "Overlay synced kinetic lyrics on any music tab — YouTube, Spotify, SoundCloud, and more.",
  "minimum_chrome_version": "116",
  "permissions": [
    "activeTab",
    "scripting",
    "tabCapture",
    "offscreen",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://lyricvibe.onrender.com/*",
    "https://open.spotify.com/*",
    "https://music.youtube.com/*",
    "https://www.youtube.com/*",
    "https://soundcloud.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_title": "Start LyricVibe"
  },
  "background": {
    "service_worker": "service-worker.js"
  }
}
